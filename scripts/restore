#!/bin/bash
# ═══════════════════════════════════════════════════════════
#  ACCESSIA Pro — Script de restauration YunoHost
# ═══════════════════════════════════════════════════════════
set -eu

source /usr/share/yunohost/helpers

app=$YNH_APP_INSTANCE_NAME
install_dir=$(ynh_app_setting_get --key=install_dir)
data_dir=$(ynh_app_setting_get --key=data_dir)
port_backend=$(ynh_app_setting_get --key=port_backend)
domain=$(ynh_app_setting_get --key=domain)

#=================================================
# RESTAURATION DE LA BASE DE DONNÉES
#=================================================
ynh_script_progression "Restauration de la base de données..."

mkdir -p "$data_dir/_ACCESSIA_APP"

if [ -f "$YNH_CWD/sensia.db" ]; then
    cp "$YNH_CWD/sensia.db" "$data_dir/_ACCESSIA_APP/sensia.db"
    [ -f "$YNH_CWD/sensia.db-wal" ] && cp "$YNH_CWD/sensia.db-wal" "$data_dir/_ACCESSIA_APP/sensia.db-wal" || true
    [ -f "$YNH_CWD/sensia.db-shm" ] && cp "$YNH_CWD/sensia.db-shm" "$data_dir/_ACCESSIA_APP/sensia.db-shm" || true
    chown "$app:$app" "$data_dir/_ACCESSIA_APP/sensia.db"* 2>/dev/null || true
    chmod 640 "$data_dir/_ACCESSIA_APP/sensia.db"
else
    ynh_print_warn "Aucun backup de base de données trouvé — démarrage avec une DB vide"
fi

#=================================================
# RESTAURATION DE LA CONFIG DOCKER
#=================================================
ynh_script_progression "Restauration de la configuration Docker..."

# SECURITY FIX: syntaxe positionnelle correcte (helpers v2.1)
ynh_restore "$install_dir/docker-compose.override.yml"
chmod 600 "$install_dir/docker-compose.override.yml"
chown root:root "$install_dir/docker-compose.override.yml"

#=================================================
# REDÉMARRAGE DES CONTENEURS
#=================================================
ynh_script_progression "Redémarrage des conteneurs..."

docker compose \
    --project-name accessia \
    -f "$install_dir/docker-compose.yml" \
    -f "$install_dir/docker-compose.override.yml" \
    up --detach

#=================================================
# RESTAURATION NGINX
#=================================================
ynh_script_progression "Restauration nginx..."

ynh_restore "/etc/nginx/conf.d/$domain.d/$app.conf"
# SECURITY FIX: ynh_systemctl n'existe pas en helpers v2.1 pour nginx
systemctl reload nginx

ynh_script_progression "Restauration terminée."
