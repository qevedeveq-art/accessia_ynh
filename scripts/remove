#!/bin/bash
# ═══════════════════════════════════════════════════════════
#  ACCESSIA Pro — Script de suppression YunoHost
# ═══════════════════════════════════════════════════════════
set -eu

source /usr/share/yunohost/helpers

app=$YNH_APP_INSTANCE_NAME
install_dir=$(ynh_app_setting_get --key=install_dir)

#=================================================
# ARRÊT ET SUPPRESSION DES CONTENEURS
#=================================================
ynh_script_progression "Arrêt des conteneurs Docker..."

if [ -f "$install_dir/docker-compose.yml" ]; then
    # BUG FIX: --project-name cohérent avec l'install
    docker compose \
        --project-name accessia \
        -f "$install_dir/docker-compose.yml" \
        -f "$install_dir/docker-compose.override.yml" \
        down --volumes --remove-orphans 2>/dev/null || true
fi

# Supprimer les images du projet accessia uniquement
docker image prune -f --filter "label=com.docker.compose.project=accessia" 2>/dev/null || true

#=================================================
# SUPPRESSION NGINX
#=================================================
ynh_remove_nginx_config

# Les données dans data_dir sont conservées par YunoHost (sauf --purge)
# Pour tout supprimer : yunohost app remove accessia --purge

ynh_script_progression "Suppression terminée."
