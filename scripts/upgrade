#!/bin/bash
# ═══════════════════════════════════════════════════════════
#  ACCESSIA Pro — Script de mise à jour YunoHost
# ═══════════════════════════════════════════════════════════
set -eu

source /usr/share/yunohost/helpers

app=$YNH_APP_INSTANCE_NAME
install_dir=$(ynh_app_setting_get --key=install_dir)
data_dir=$(ynh_app_setting_get --key=data_dir)
port=$(ynh_app_setting_get --key=port)
port_backend=$(ynh_app_setting_get --key=port_backend)
domain=$(ynh_app_setting_get --key=domain)
secret_key=$(ynh_app_setting_get --key=secret_key)

#=================================================
# BACKUP PRÉALABLE DE LA BASE DE DONNÉES
#=================================================
ynh_script_progression "Backup de la base de données avant mise à jour..."

backup_file="$data_dir/backups/sensia_pre_upgrade_$(date +%Y%m%d_%H%M%S).db"
if [ -f "$data_dir/_ACCESSIA_APP/sensia.db" ]; then
    cp "$data_dir/_ACCESSIA_APP/sensia.db" "$backup_file"
    ynh_print_info "Backup créé : $backup_file"
fi

#=================================================
# PULL DU CODE SOURCE
#=================================================
ynh_script_progression "Mise à jour du code source..."

ynh_exec_as_app git -C "$install_dir" pull --rebase

#=================================================
# ARRÊT DES CONTENEURS
#=================================================
ynh_script_progression "Arrêt des conteneurs..."

ynh_exec_as_app docker compose \
    -f "$install_dir/CRM/docker-compose.yml" \
    -f "$install_dir/CRM/docker-compose.override.yml" \
    down

#=================================================
# REGÉNÉRATION DE LA CONFIG DOCKER
#=================================================
ynh_script_progression "Regénération de la configuration..."

ynh_add_config \
    --template="docker-compose.override.yml" \
    --destination="$install_dir/CRM/docker-compose.override.yml" \
    --vars="
domain=$domain
port=$port
port_backend=$port_backend
secret_key=$secret_key
data_dir=$data_dir
install_dir=$install_dir/CRM
"

chmod 600 "$install_dir/CRM/docker-compose.override.yml"

#=================================================
# REBUILD ET REDÉMARRAGE
#=================================================
ynh_script_progression "Rebuild Docker..."

ynh_exec_as_app docker compose \
    -f "$install_dir/CRM/docker-compose.yml" \
    -f "$install_dir/CRM/docker-compose.override.yml" \
    up --build --detach

#=================================================
# MISE À JOUR NGINX
#=================================================
ynh_add_nginx_config --vars="port_backend=$port_backend"

ynh_script_progression "Mise à jour terminée !"
