#!/bin/bash
# ═══════════════════════════════════════════════════════════
#  ACCESSIA Pro — Script de mise à jour YunoHost
# ═══════════════════════════════════════════════════════════
set -eu

source /usr/share/yunohost/helpers

app=$YNH_APP_INSTANCE_NAME
install_dir=$(ynh_app_setting_get --key=install_dir)
data_dir=$(ynh_app_setting_get --key=data_dir)
port=$(ynh_app_setting_get --key=port)
port_backend=$(ynh_app_setting_get --key=port_backend)
domain=$(ynh_app_setting_get --key=domain)
secret_key=$(ynh_app_setting_get --key=secret_key)

#=================================================
# BACKUP PRÉVENTIF DE LA BASE DE DONNÉES
#=================================================
ynh_script_progression "Backup de la base de données avant mise à jour..."

db_path="$data_dir/_ACCESSIA_APP/sensia.db"
backup_file="$data_dir/backups/sensia_pre_upgrade_$(date +%Y%m%d_%H%M%S).db"

if [ -f "$db_path" ]; then
    sqlite3 "$db_path" "PRAGMA wal_checkpoint(FULL);" 2>/dev/null || true
    cp "$db_path" "$backup_file"
    ynh_print_info "Backup : $backup_file"
    ls -t "$data_dir/backups/sensia_pre_upgrade_"*.db 2>/dev/null | tail -n +11 | xargs rm -f || true
fi

#=================================================
# ARRÊT DES CONTENEURS (avant git pull)
# Le backend monte install_dir en :rw — on stoppe d'abord
# pour éviter que git pull --rebase échoue sur des fichiers
# modifiés par le conteneur en cours d'exécution.
#=================================================
ynh_script_progression "Arrêt des conteneurs..."

docker-compose \
    --project-name accessia \
    -f "$install_dir/docker-compose.yml" \
    -f "$install_dir/docker-compose.override.yml" \
    down || true

#=================================================
# MISE À JOUR DU CODE SOURCE
# Utilise fetch + reset --hard pour gérer proprement
# les éventuelles modifications locales de fichiers trackés.
#=================================================
ynh_script_progression "Mise à jour du code source..."

git -C "$install_dir" fetch origin
git -C "$install_dir" reset --hard origin/HEAD

chown -R "$app:$app" "$install_dir"

#=================================================
# REGÉNÉRATION DE LA CONFIG
#=================================================
ynh_script_progression "Regénération de la configuration Docker..."

export domain port port_backend secret_key data_dir install_dir

ynh_config_add \
    --template="docker-compose.override.yml" \
    --destination="$install_dir/docker-compose.override.yml"

chmod 600 "$install_dir/docker-compose.override.yml"
chown root:root "$install_dir/docker-compose.override.yml"

#=================================================
# REBUILD ET REDÉMARRAGE
#=================================================
ynh_script_progression "Rebuild et redémarrage Docker..."

docker-compose \
    --project-name accessia \
    -f "$install_dir/docker-compose.yml" \
    -f "$install_dir/docker-compose.override.yml" \
    up --build --detach

#=================================================
# MISE À JOUR NGINX
#=================================================
export port_backend
ynh_config_add_nginx

#=================================================
# VÉRIFICATION DU DÉMARRAGE
#=================================================
ynh_script_progression "Vérification du démarrage (max 60s)..."

for i in $(seq 1 12); do
    if curl -sf "http://127.0.0.1:$port_backend/api/health" &>/dev/null; then
        ynh_print_info "Backend opérationnel (tentative $i/12)."
        break
    fi
    if [ "$i" -eq 12 ]; then
        ynh_die "Le backend n'a pas répondu après 60s. Diagnostiquer : docker logs accessia-backend-1"
    fi
    sleep 5
done

ynh_script_progression "Mise à jour terminée !"
