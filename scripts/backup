#!/bin/bash
# ═══════════════════════════════════════════════════════════
#  ACCESSIA Pro — Script de backup YunoHost
# ═══════════════════════════════════════════════════════════
set -eu

source /usr/share/yunohost/helpers

app=$YNH_APP_INSTANCE_NAME
install_dir=$(ynh_app_setting_get --key=install_dir)
data_dir=$(ynh_app_setting_get --key=data_dir)
domain=$(ynh_app_setting_get --key=domain)

#=================================================
# BACKUP SQLITE (WAL-safe)
#=================================================
ynh_script_progression "Sauvegarde de la base de données SQLite..."

db_path="$data_dir/_ACCESSIA_APP/sensia.db"

if [ -f "$db_path" ]; then
    sqlite3 "$db_path" "PRAGMA wal_checkpoint(FULL);" 2>/dev/null || true
    cp "$db_path" "$YNH_CWD/sensia.db"
    [ -f "${db_path}-wal" ] && cp "${db_path}-wal" "$YNH_CWD/sensia.db-wal" || true
    [ -f "${db_path}-shm" ] && cp "${db_path}-shm" "$YNH_CWD/sensia.db-shm" || true
else
    ynh_print_warn "Base de données introuvable à $db_path — backup ignoré"
fi

#=================================================
# BACKUP DE LA CONFIGURATION DOCKER
#=================================================
ynh_script_progression "Sauvegarde de la configuration Docker..."

# SECURITY FIX: syntaxe positionnelle correcte (helpers v2.1) — pas de --src_path
ynh_backup "$install_dir/docker-compose.override.yml"

#=================================================
# BACKUP NGINX
#=================================================
ynh_script_progression "Sauvegarde de la configuration nginx..."

ynh_backup "/etc/nginx/conf.d/$domain.d/$app.conf"

ynh_script_progression "Backup terminé."
