#!/bin/bash
# ═══════════════════════════════════════════════════════════
#  ACCESSIA Pro — Script d'installation YunoHost
# ═══════════════════════════════════════════════════════════
set -eu

source /usr/share/yunohost/helpers

#=================================================
# VARIABLES (injectées par YunoHost resources)
#=================================================
domain=$YNH_APP_ARG_DOMAIN
app=$YNH_APP_INSTANCE_NAME

install_dir=$(ynh_app_setting_get --key=install_dir)
data_dir=$(ynh_app_setting_get --key=data_dir)
port=$(ynh_app_setting_get --key=port)
port_backend=$(ynh_app_setting_get --key=port_backend)

#=================================================
# VÉRIFICATION DOCKER
#=================================================
ynh_script_progression "Vérification de Docker..."

if ! command -v docker &>/dev/null; then
    ynh_die "Docker n'est pas installé malgré la dépendance apt — vérifiez les logs."
fi

#=================================================
# GÉNÉRATION DE LA CLÉ SECRÈTE
#=================================================
ynh_script_progression "Génération des secrets..."

secret_key=$(ynh_string_random --length=64)
ynh_app_setting_set --key=secret_key --value="$secret_key"

#=================================================
# CLONE DU DÉPÔT SOURCE
#=================================================
ynh_script_progression "Clonage du code source..."

REPO_URL="https://github.com/qevedeveq-art/accessia-crm.git"

if [ -d "$install_dir/.git" ]; then
    git -C "$install_dir" pull --rebase
else
    git clone "$REPO_URL" "$install_dir"
fi
chown -R "$app:$app" "$install_dir"

#=================================================
# RÉPERTOIRES DE DONNÉES
#=================================================
ynh_script_progression "Création des répertoires de données..."

mkdir -p "$data_dir/_ACCESSIA_APP"
mkdir -p "$data_dir/backups"

chown -R "$app:$app" "$data_dir"
chmod 750 "$data_dir"
chmod 700 "$data_dir/_ACCESSIA_APP"

#=================================================
# GÉNÉRATION DE LA CONFIG DOCKER COMPOSE
#=================================================
ynh_script_progression "Génération de la configuration Docker..."

# ynh_config_add substitue __VAR__ depuis les variables shell (helpers v2.1)
export domain port port_backend secret_key data_dir install_dir

# SECURITY FIX: nom correct helpers v2.1 (ynh_add_config → ynh_config_add)
ynh_config_add \
    --template="docker-compose.override.yml" \
    --destination="$install_dir/docker-compose.override.yml"

# Le fichier contient SECRET_KEY — accès root uniquement
chmod 600 "$install_dir/docker-compose.override.yml"
chown root:root "$install_dir/docker-compose.override.yml"

#=================================================
# BUILD ET DÉMARRAGE DOCKER
#=================================================
ynh_script_progression "Build Docker (5-10 minutes)..."

# Scripts d'install tournent en root — pas besoin de ynh_exec_as_app pour Docker
docker-compose \
    --project-name accessia \
    -f "$install_dir/docker-compose.yml" \
    -f "$install_dir/docker-compose.override.yml" \
    up --build --detach

#=================================================
# CONFIGURATION NGINX
#=================================================
ynh_script_progression "Configuration nginx..."

# SECURITY FIX: nom correct helpers v2.1 (ynh_add_nginx_config → ynh_config_add_nginx)
export port_backend
ynh_config_add_nginx

#=================================================
# VÉRIFICATION DU DÉMARRAGE
#=================================================
ynh_script_progression "Vérification du démarrage (max 60s)..."

for i in $(seq 1 12); do
    if curl -sf "http://127.0.0.1:$port_backend/api/health" &>/dev/null; then
        ynh_print_info "Backend opérationnel (tentative $i/12)."
        break
    fi
    if [ "$i" -eq 12 ]; then
        ynh_die "Le backend n'a pas répondu. Diagnostiquer avec : docker logs accessia-backend-1"
    fi
    sleep 5
done

#=================================================
# FIN
#=================================================
ynh_script_progression "Installation terminée !"
ynh_print_info "ACCESSIA Pro → https://$domain"
ynh_print_info "API docs     → https://$domain/api/docs"
